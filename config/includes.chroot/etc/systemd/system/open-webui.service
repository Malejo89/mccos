[Unit]
Description=Open WebUI Docker Container
Requires=docker.service
After=docker.service network-online.target

[Service]
Restart=always
ExecStartPre=-/usr/bin/docker stop open-webui
ExecStartPre=-/usr/bin/docker rm open-webui
ExecStart=/usr/bin/docker run --name open-webui --network host -v open-webui-data:/app/backend/data -e OLLAMA_BASE_URL=http://127.0.0.1:11434 ghcr.io/open-webui/open-webui:main
ExecStop=/usr/bin/docker stop open-webui

[Install]
WantedBy=multi-user.target
