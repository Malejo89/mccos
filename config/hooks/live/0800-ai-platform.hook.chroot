#!/bin/sh

set -e

echo "Running 0800-ai-platform.hook.chroot: Installing AI Platform..."

export DEBIAN_FRONTEND=noninteractive

# 1. Install Ollama
echo "Installing Ollama..."
curl -fsSL https://ollama.com/install.sh | sh

# 2. Enable Open WebUI service
# (The service file is placed via includes.chroot/etc/systemd/system/open-webui.service)
echo "Enabling Open WebUI systemd service..."
systemctl enable open-webui.service

# Note: No LLM models are pulled during the ISO build to keep the size small.
# Models will be downloaded post-install via the MCC Model Manager.

echo "AI platform hook completed."
